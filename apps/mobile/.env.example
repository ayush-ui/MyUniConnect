# Base URL for the MyUniConnect API.
# iOS Simulator (same machine as API): http://localhost:3001
# Android Emulator: http://10.0.2.2:3001
# Physical device / Android emulator (external host): http://<your-lan-ip>:3001
EXPO_PUBLIC_API_URL=http://localhost:3001

# Public base URL for Hetzner Object Storage (path-style: https://{endpoint}/{bucket})
EXPO_PUBLIC_STORAGE_BASE_URL=https://nbg1.your-objectstorage.com/uniconnect
