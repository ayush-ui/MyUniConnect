{
  "expo": {
    "name": "UniSync",
    "slug": "unisync",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "unisync",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/brand/icon/unisync-icon-1024.png",
    "splash": {
      "image": "./assets/brand/mark/unisync-mark-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.unisync.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/mark/unisync-mark-1024.png",
        "backgroundColor": "#2E5559"
      },
      "package": "com.unisync.app"
    },
    "web": {
      "favicon": "./assets/brand/icon/unisync-icon-64.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/mark/unisync-mark-1024.png",
          "backgroundColor": "#FAF8F5",
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
